<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>App_or_CoApp_in_Region__c</fullName>
    <externalId>false</externalId>
    <formula>IF( 
OR(
HOMEtracker__Applicant__r.Address_COAH_Region__c =  TEXT(HOMEtracker__Property__r.COAH_Regions__c ),
 HOMEtracker__Co_Applicant__r.Address_COAH_Region__c  =  TEXT(HOMEtracker__Property__r.COAH_Regions__c )
)
,&quot;YES&quot;,&quot;??&quot;)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>If either the primary applicant or the co-applicant live in the region of the property, this will say &quot;Yes&quot;.</inlineHelpText>
    <label>App or CoApp Live in Region</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
