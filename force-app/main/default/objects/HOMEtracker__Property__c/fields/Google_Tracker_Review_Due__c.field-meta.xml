<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Google_Tracker_Review_Due__c</fullName>
    <externalId>false</externalId>
    <formula>IF(CASE(TEXT(Google_Tracker_Review__c),
&quot;Daily&quot;,IF(OR(ISBLANK(Google_Tracker_Review_Date__c),Google_Tracker_Weekdays_Unchecked__c&gt;0),1,0),
&quot;2 Days&quot;,IF(OR(ISBLANK(Google_Tracker_Review_Date__c),Google_Tracker_Weekdays_Unchecked__c&gt;2),1,0),
&quot;Weekly&quot;,IF(OR(ISBLANK(Google_Tracker_Review_Date__c),Google_Tracker_Weekdays_Unchecked__c&gt;7),1,0),
0)=1,&quot;REVIEW NEEDED&quot;,&quot;reviewed&quot;)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Google Tracker Review Due</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
