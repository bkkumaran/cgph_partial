<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Region_Check__c</fullName>
    <description>Checks to see if the region on the development matches the region on the municipality. They should be the same.</description>
    <externalId>false</externalId>
    <formula>IF(AND(CONTAINS(TEXT(Municipality_Name__r.Region__c),&quot;1&quot;),CONTAINS(TEXT(COAH_Regions__c),&quot;1&quot;)),&quot;OK&quot;,

IF(AND(CONTAINS(TEXT(Municipality_Name__r.Region__c),&quot;2&quot;),CONTAINS(TEXT(COAH_Regions__c),&quot;2&quot;)),&quot;OK&quot;,

IF(AND(CONTAINS(TEXT(Municipality_Name__r.Region__c),&quot;3&quot;),CONTAINS(TEXT(COAH_Regions__c),&quot;3&quot;)),&quot;OK&quot;,

IF(AND(CONTAINS(TEXT(Municipality_Name__r.Region__c),&quot;4&quot;),CONTAINS(TEXT(COAH_Regions__c),&quot;4&quot;)),&quot;OK&quot;,

IF(AND(CONTAINS(TEXT(Municipality_Name__r.Region__c),&quot;5&quot;),CONTAINS(TEXT(COAH_Regions__c),&quot;5&quot;)),&quot;OK&quot;,

IF(AND(CONTAINS(TEXT(Municipality_Name__r.Region__c),&quot;6&quot;),CONTAINS(TEXT(COAH_Regions__c),&quot;6&quot;)),&quot;OK&quot;,

&quot;ERROR&quot;))))))</formula>
    <inlineHelpText>Checks to see if the region on the development matches the region on the municipality. They should be the same.</inlineHelpText>
    <label>Region Check</label>
    <required>false</required>
